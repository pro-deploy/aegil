# Крошечный образ node-agent продукта aegil: чистый сервер на стандартной библиотеке Python
# без внешних зависимостей. Единственная системная добавка это util-linux, откуда берётся nsenter
# для входа в пространство имён хоста. Никаких pip-пакетов, поэтому образ остаётся минимальным.
#
# База закреплена по конкретной минорной версии. Тег python:3.11-slim подвижен и со временем
# указывает на другой образ, из-за чего одна и та же версия node-agent собралась бы из разной базы.
# Для полной воспроизводимости базу следует пинить по дайджесту в форме
# python:3.11-slim@sha256:<дайджест>, где дайджест берётся из реестра при сборке и пересматривается
# осознанно при обновлении базы. Дайджест не вписан в файл, чтобы не закрепить непроверенное
# значение; его подставляет конвейер сборки.
FROM python:3.11-slim
WORKDIR /app
RUN apt-get update \
    && apt-get install -y --no-install-recommends util-linux \
    && rm -rf /var/lib/apt/lists/*
# В прод-образ копируется ТОЛЬКО модуль сервиса. Тесты (test_node_agent.py) в образ не попадают:
# они не нужны в промышленной эксплуатации и лишь расширяют поверхность образа. Внешних
# зависимостей и requirements.txt нет.
COPY app.py ./
EXPOSE 9110
# Пользователя намеренно НЕ понижаем и оставляем root. Это обосновано назначением сервиса: через
# nsenter -t 1 он входит в пространства имён процесса PID 1 (самого хоста), а операция setns над
# пространствами хоста и последующее исполнение команд на узле требуют капабилити SYS_ADMIN и
# SYS_PTRACE, которые в манифесте выданы именно процессу root внутри контейнера. Понижение
# пользователя лишило бы сервис его единственной функции.
USER root
CMD ["python", "app.py"]
