# Пример конфигурации aegil. Скопируйте в .env или задайте как переменные окружения
# подов и ключи секрета aegil-secrets. Единый префикс AEGIL_ для всей конфигурации
# продукта (docs/CONVENTIONS.md). Значения по умолчанию нейтральны и не привязаны ни к какому
# приложению. Наследные имена (PANEL_*, NAMESPACE, RCA_URL, LLM_SERVICE_URL, KROKKI_*) упразднены.

# --- Панель агента ---
# Аллоу-лист операторов «имя:токен» через запятую. Единственный вход в панель, fail-closed.
# Кладётся в секрет aegil-secrets ключом AEGIL_OPERATORS.
AEGIL_OPERATORS=admin:CHANGE_ME_TO_A_LONG_RANDOM_TOKEN

# Наблюдаемое и управляемое пространство имён. В подах заполняется автоматически из downward API
# (fieldRef metadata.namespace); задавайте здесь только для запуска вне кластера.
AEGIL_NAMESPACE=aegil

# Метка роли узла для дружеских имён в командах оператора. Если метки нет, агент оперирует
# именами узлов как есть; зашитых имён узлов в продукте нет.
AEGIL_NODE_ROLE_LABEL=node-role.kubernetes.io/role

# --- Уровень автономии и политика ---
# Уровень автономии: observe (сухой прогон, только наблюдение и предложения, по умолчанию),
# safe_repair (автономно read и safe_write, destructive и защищённые шаблоны за подтверждением),
# full (автономно всё, кроме destructive и защищённых шаблонов). Меняется владельцем.
AEGIL_AUTONOMY=observe
# Безсостоятельные сервисы, которые агент может перезапускать автономно (через запятую).
# Пусто означает: автономный перезапуск выключен, пока вы не перечислите свои сервисы.
AEGIL_RESTART_ALLOWLIST=
# Сервисы, перезапуск которых запрещён всегда (хранилища и особые поды).
AEGIL_RESTART_DENYLIST=postgres,redis,minio,etcd,vault
# Защищаемые ресурсы и пути: действия над ними всегда требуют подтверждения оператора независимо
# от уровня автономии. Заменяет наследный доменный класс. По умолчанию пусто, вносит владелец.
AEGIL_PROTECTED_PATTERNS=

# --- Языковая модель агентного цикла ---
# Провайдер протокола вызова инструментов: anthropic (по умолчанию) или openai-совместимый.
AEGIL_LLM_PROVIDER=anthropic
# Идентификатор модели. По умолчанию (при пустом значении) используется claude-opus-4-8.
AEGIL_LLM_MODEL=claude-opus-4-8
# Ключ доступа к модели. Кладётся в секрет aegil-secrets ключом AEGIL_LLM_API_KEY. Пустой
# ключ означает, что агентный цикл выключен и панель работает как исполнитель одиночных команд.
AEGIL_LLM_API_KEY=
# Базовый адрес, необязателен. Пусто для облачной модели; задайте для своей модели в кластере
# (vLLM, Ollama или совместимый прокси), например http://vllm:8000/v1.
AEGIL_LLM_BASE_URL=

# --- Открытые серверы MCP (дополнительные инструменты агента) ---
# JSON-список серверов Model Context Protocol: [{"name","url","read_only","token"}]. Пусто означает,
# что MCP выключен. Помечайте read_only:true только читающие серверы наблюдаемости (Grafana,
# Prometheus, Loki, Tempo): их инструменты агент вызывает свободно для диагноза. Инструменты сервера
# без пометки read_only требуют подтверждения оператора (структурированный вызов не классифицируется
# гейтом argv, поэтому трактуется консервативно как потенциальная мутация).
AEGIL_MCP_SERVERS=

# --- Канал самообновления продукта ---
# Текущая версия продукта, должна совпадать с тегом образа (правило версионирования).
AEGIL_VERSION=0.1.0
# Адрес канала выпусков, отдающий JSON {"version","image_tag","notes"}. Пусто выключает проверку.
AEGIL_UPDATE_CHANNEL_URL=
# Деплойменты, теги образов которых обновляются при подтверждённом владельцем обновлении (через
# запятую, например agent-panel,rca,node-agent). Пусто означает, что обновление не тронет ничего.
# Применение обновления всегда требует явного подтверждения владельца, автономно не выполняется.
AEGIL_UPDATE_DEPLOYMENTS=

# --- Узловой агент ---
# Токен доступа панели к node-agent (тот же секрет кладётся и в DaemonSet node-agent).
# Кладётся в секрет aegil-secrets ключом AEGIL_NODEAGENT_TOKEN.
AEGIL_NODEAGENT_TOKEN=CHANGE_ME_TO_A_LONG_RANDOM_TOKEN
# Таймаут запроса к node-agent в секундах.
AEGIL_NODEAGENT_TIMEOUT=30

# --- Наблюдаемость ---
# Сервис детерминированного разбора первопричин (RCA) внутри кластера.
AEGIL_RCA_URL=http://rca:9107
# Лог-хранилище Loki и селектор потоков. По умолчанию потоки наблюдаемого пространства имён,
# без зашитого имени: подставьте своё пространство вместо переменной, если запускаете вне кластера.
AEGIL_LOKI_URL=http://loki:3100
AEGIL_LOKI_QUERY={namespace="aegil"}
# Grafana для перекрёстных ссылок логов и трасс (необязательно).
AEGIL_GRAFANA_URL=http://grafana:3000
AEGIL_GRAFANA_TOKEN=

# --- Postgres (обязателен для RCA и тренера) ---
# Строка подключения к Postgres, где RCA хранит размеченные примеры для активного обучения.
# Кладётся в секрет aegil-secrets ключом AEGIL_POSTGRES_DSN.
AEGIL_POSTGRES_DSN=postgresql://aegil:CHANGE_ME@postgres:5432/aegil

# --- Объектное хранилище S3 (обязательно для синхронизации модели маршрутизации) ---
# Эндпоинт, ключи, бакет и префикс ключа модели. Ключи кладутся в секрет aegil-secrets.
AEGIL_S3_ENDPOINT=https://s3.example.com
AEGIL_S3_ACCESS_KEY=CHANGE_ME
AEGIL_S3_SECRET_KEY=CHANGE_ME
AEGIL_S3_BUCKET=aegil
AEGIL_MODEL_KEY_PREFIX=rca/setfit-router.tar.gz

# --- Пороги детекторов симптомов (необязательно, у всех разумные умолчания) ---
# Заполнение файловых систем узла: предупреждение и критично, проценты.
AEGIL_DISK_WARN=80
AEGIL_DISK_CRIT=90
# Заполнение памяти узла, процент.
AEGIL_MEM_WARN=90
# Шторм перезапусков пода: порог рестартов за окно (секунды).
AEGIL_RESTART_STORM_THRESHOLD=5
AEGIL_RESTART_WINDOW_SECONDS=3600
# Возраст пода в состоянии Pending, после которого это симптом (секунды).
AEGIL_PENDING_AGE_SECONDS=300
# Срок действия TLS-сертификата: предупреждение и высокая важность, дни. Хост проверки в
# AEGIL_TLS_HOST (пусто означает, что срок TLS не проверяется).
AEGIL_TLS_WARN_DAYS=14
AEGIL_TLS_HIGH_DAYS=7
AEGIL_TLS_HOST=

# --- Необязательный адаптер управляемого приложения ---
# Если заданы, агент может вызывать прикладные действия целевого приложения через HTTP-адаптер.
# Без них адаптер выключен, и агент опирается только на инфраструктурный ремонт.
AEGIL_APP_ADMIN_URL=
AEGIL_APP_ADMIN_TOKEN=

# --- Grafana (стек наблюдаемости) ---
# Логин и пароль администратора Grafana. Кладутся в отдельный секрет grafana-admin ключами
# user и password.
AEGIL_GRAFANA_ADMIN_USER=admin
AEGIL_GRAFANA_ADMIN_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_TOKEN
