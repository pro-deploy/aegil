# Пример конфигурации kube-sentinel. Скопируйте в .env или задайте как переменные окружения
# подов. Значения по умолчанию нейтральны и не привязаны ни к какому приложению.

# --- Панель агента (agent-panel) ---
# Аллоу-лист операторов «имя:токен» через запятую. Единственный вход в панель, fail-closed.
PANEL_OPERATORS=admin:CHANGE_ME_TO_A_LONG_RANDOM_TOKEN
# Интерфейс прослушивания панели (только localhost или адрес туннеля, наружу не публикуется).
PANEL_HOST=127.0.0.1

# --- Внешние системы, к которым подключается продукт ---
# Пространство имён Kubernetes для наблюдения и действий.
NAMESPACE=sentinel
# Сервис разбора логов (RCA) внутри кластера.
RCA_URL=http://rca:9107
# Языковая модель (OpenAI-совместимый или локальный прокси, отдающий {"text": ...} на /completion).
LLM_SERVICE_URL=http://llm:9102
# Лог-хранилище Loki и селектор потоков (по умолчанию все потоки пространства).
LOKI_URL=http://loki:3100
LOKI_QUERY={namespace="sentinel"}
# Токен доступа панели к node-agent (тот же секрет кладётся и в DaemonSet node-agent).
NODEAGENT_TOKEN=CHANGE_ME_TO_A_LONG_RANDOM_TOKEN

# --- Политика агента ---
# Безсостоятельные сервисы, которые агент может перезапускать автономно (через запятую).
# Пусто означает: автономный перезапуск выключен, пока вы не перечислите свои сервисы.
RESTART_ALLOWLIST=
# Сервисы, перезапуск которых запрещён всегда (хранилища и особые поды).
RESTART_DENYLIST=postgres,redis,minio,etcd,vault
# Автономный ремонт. Выключено по умолчанию: сухой прогон (наблюдение и эскалации). Включите
# после того, как убедились в правильности решений агента на вашем кластере.
AGENT_AUTONOMOUS=0
# Пороги алертов.
ALERT_DISK_WARN=80
ALERT_DISK_CRIT=90
# Хост для проверки срока TLS-сертификата (необязательно).
TLS_HOST=

# --- Необязательный адаптер управляемого приложения ---
# Если задан, агент может вызывать прикладные действия целевого приложения (например возврат
# застрявшей задачи в очередь). Без этих переменных прикладной адаптер выключен, и агент
# опирается только на инфраструктурный ремонт.
APP_ADMIN_URL=
APP_ADMIN_TOKEN=
